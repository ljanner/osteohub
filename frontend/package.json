{
  "name": "osteohub",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --browsers=Chrome",
    "test:headless": "ng test --browsers=ChromeHeadless",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "lint:sass": "stylelint **.scss",
    "lint:sass:fix": "stylelint --fix **.scss",
    "lint:all": "pnpm lint && pnpm lint:sass"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@angular/cdk": "^21.1.4",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@siemens/element-icons": "1.0.2",
    "@siemens/element-ng": "49.0.0",
    "@siemens/element-theme": "49.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.2.0",
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "@siemens/eslint-config-angular": "4.1.0",
    "@siemens/stylelint-config-scss": "4.1.0",
    "@vitest/browser-webdriverio": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^27.1.0",
    "postcss-scss": "4.0.9",
    "stylelint": "17.2.0",
    "stylelint-scss": "7.0.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
